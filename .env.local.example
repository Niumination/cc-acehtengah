# ─── cc-acehtengah Environment Config ───

# Mock data mode (true = data presentasi, false = live SAPA API)
USE_MOCK_DATA=true

# ─── AI Provider (OpenAI-compatible) ───
# Supported: OpenAI, OpenRouter, Groq, Together, DeepSeek, etc.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini

# ─── Qdrant (opsional — skip jika tidak ada) ───
# QDRANT_URL=http://localhost:6333
