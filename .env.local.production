# ─── Database ───
# PostgreSQL connection (required for datasets sync & history)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL="postgresql://user:***@localhost:5432/cc_acehtengah"

# ─── SPLP / SAPA Integration ───
# SAPA API public (already working, no auth needed)
# SPLP_TOKEN="your-splp-token-here"  # Not used currently - SAPA is public

# ─── AI / LLM (OpenAI-compatible) ───
# NO DOCKER NEEDED - use any cloud provider:
#   - OpenRouter:     https://openrouter.ai/api/v1     (models: gpt-4o, claude-3.5, deepseek, etc)
#   - Groq:           https://api.groq.com/openai/v1   (free tier: llama-3.1-70b, mixtral)
#   - Together:       https://api.together.xyz/v1      (many open models)
#   - DeepSeek:       https://api.deepseek.com/v1      (deepseek-chat, deepseek-coder)
#   - Huancheng:      https://api.hcnsec.cn/v1         (your OpenCode provider)
#   - OpenAI:         https://api.openai.com/v1        (gpt-4o, gpt-4o-mini)
#
# SET THESE THREE:
AI_BASE_URL="https://api.openrouter.ai/v1"
AI_API_KEY="sk-or-***"  # Get from your provider dashboard
AI_MODEL="gpt-4o-mini"  # Or: deepseek-chat, llama-3.1-70b-versatile, etc

# ─── Vector DB (Qdrant) - OPTIONAL ───
# RAG works WITHOUT Qdrant - falls back gracefully to empty context
# Only set if you have Qdrant running (Docker/cloud)
# QDRANT_URL="http://localhost:6333"

# ─── NextAuth (future) ───
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Mock Data untuk Presentasi / Dev ───
# SET TRUE untuk demo tanpa DB/AI/Qdrant (pakai data real cc.acehtengahkab.go.id)
# SET FALSE untuk production dengan real SAPA + AI
USE_MOCK_DATA=false
